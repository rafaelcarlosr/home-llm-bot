# Telegram Bot Token
TELEGRAM_TOKEN=your_telegram_bot_token_here

# LM Studio (running on desktop)
LM_STUDIO_URL=http://192.168.1.100:1234

# Home Assistant
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=your_ha_token_here

# Whisper STT
WHISPER_URL=http://localhost:9000

# SQLite Database (in container: /app/data/bot.db)
DATABASE_URL=sqlite:///app/data/bot.db
